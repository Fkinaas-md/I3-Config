eval "$(starship init zsh)"
# Правильные пути для Arch Linux:
source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
ZSH_HIGHLIGHT_STYLES[command]='fg=#bd93f9,bold'      # Фиолетовый для команд
ZSH_HIGHLIGHT_STYLES[argument]='fg=#8be9fd'         # Циановый для аргументов
ZSH_HIGHLIGHT_STYLES[path]='fg=#f1fa8c,underline'   # Желтый с подчеркиванием для путей

